---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import NewsCard from '../../components/NewsCard.astro';
import FeaturedNews from '../../components/FeaturedNews.astro';
import { getNews } from '../../lib/newsService';
import { CATEGORIES } from '../../lib/config';

const { category } = Astro.params;
const url = new URL(Astro.request.url);
const isEducational = url.searchParams.has('educational');

if (!category || !CATEGORIES.includes(category.toLowerCase())) {
  return new Response("Not found", { status: 404 });
}

let allNews = await getNews();

// Filter by category
allNews = allNews.filter(n => n.category === category.toLowerCase());

// Filter by educational mode
if (isEducational) {
  if (!['tecnología', 'cultura', 'sociedad', 'economía'].includes(category.toLowerCase())) {
    allNews = []; // Category is completely filtered out
  }
}

const featured = allNews.length > 0 ? allNews[0] : null;
const recentNews = allNews.length > 1 ? allNews.slice(1) : [];
---

<Layout title={`Noticias de ${category.charAt(0).toUpperCase() + category.slice(1)}`}>
  <Navbar />
  
  <main class="flex-grow bg-gray-50/50 pt-8 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      
      <div class="flex items-center justify-between border-b-2 border-[#CD212A] pb-3 mb-8 mt-4">
          <h1 class="text-3xl font-serif font-black text-gray-900 capitalize">{category}</h1>
      </div>

      {isEducational && (
          <div class="bg-green-50 border-l-4 border-[#008C45] p-4 rounded-r-md shadow-sm mb-8">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-[#008C45]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M19 10.5a8.5 8.5 0 11-17 0 8.5 8.5 0 0117 0zm-7 1.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3zm-2.5-4a2.5 2.5 0 115 0 2.5 2.5 0 01-5 0zm-2 7a2 2 0 114 0 2 2 0 01-4 0v-.5a.5.5 0 00-.5-.5h-.5a.5.5 0 01-.5-.5v-1a.5.5 0 01.5-.5h1.5a1.5 1.5 0 001.5-1.5v-.5a.5.5 0 00-.5-.5h-2.5a.5.5 0 01-.5-.5v-1a.5.5 0 01.5-.5h.5a.5.5 0 00.5-.5v-1.5a.5.5 0 01.5-.5h1.5a1.5 1.5 0 011.5 1.5v.5z" clip-rule="evenodd"/></svg>
              </div>
              <div class="ml-3">
                <p class="text-sm text-green-700 font-medium">
                  Modo Aula activado. Mostrando únicamente contenido educativo (Ciencia, Tecnología, Economía, Cultura y Sociedad).
                </p>
              </div>
            </div>
          </div>
      )}

      {allNews.length === 0 ? (
        <div class="text-center py-20 bg-white rounded-2xl shadow-sm border border-gray-100">
            <h2 class="text-xl text-gray-500 font-medium">No hay noticias disponibles en esta sección.</h2>
            {isEducational && <p class="text-sm text-gray-400 mt-2">El modo aula puede estar bloqueando esta categoría activa.</p>}
        </div>
      ) : (
        <>
            <section aria-label="Noticia destacada">
                {featured && <FeaturedNews article={featured} />}
            </section>

            {recentNews.length > 0 && (
                <section aria-label="Otras noticias" class="space-y-6 pt-4 border-t border-gray-100 mt-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {recentNews.map(article => (
                            <NewsCard article={article} />
                        ))}
                    </div>
                </section>
            )}
        </>
      )}
    </div>
  </main>

  <Footer />
</Layout>

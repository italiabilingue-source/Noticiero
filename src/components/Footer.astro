---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 border-t border-gray-800 mt-auto">
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:py-16 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8 xl:col-span-1">
        <span class="text-2xl font-serif font-bold text-white tracking-tight">
            Noticias<span class="text-[#008C45]">.</span><span class="text-[#CD212A]">Global</span>
        </span>
        <p class="text-gray-400 text-sm leading-6">
          Información internacional curada, segura y lista para el ámbito institucional u organizacional.
        </p>
        <div class="flex space-x-6">
          <span class="text-gray-500 hover:text-white transition-colors cursor-pointer">
            <span class="sr-only">Twitter</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
          </span>
          <span class="text-gray-500 hover:text-white transition-colors cursor-pointer">
            <span class="sr-only">LinkedIn</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/></svg>
          </span>
        </div>
      </div>
      <div class="mt-12 grid grid-cols-2 gap-8 xl:mt-0 xl:col-span-2">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold text-gray-300 tracking-wider uppercase">Secciones</h3>
            <ul role="list" class="mt-4 space-y-4">
              <li><a href="/seccion/internacional" class="text-base text-gray-400 hover:text-white transition">Internacional</a></li>
              <li><a href="/seccion/política" class="text-base text-gray-400 hover:text-white transition">Política</a></li>
              <li><a href="/seccion/economía" class="text-base text-gray-400 hover:text-white transition">Economía</a></li>
              <li><a href="/seccion/tecnología" class="text-base text-gray-400 hover:text-white transition">Tecnología</a></li>
            </ul>
          </div>
          <div class="mt-12 md:mt-0">
            <h3 class="text-sm font-semibold text-gray-300 tracking-wider uppercase">Soporte</h3>
            <ul role="list" class="mt-4 space-y-4">
              <li><a href="#" class="text-base text-gray-400 hover:text-white transition">Contacto</a></li>
              <li><a href="/admin" class="text-base text-gray-400 hover:text-white transition">Admin</a></li>
              <li><a href="#" class="text-base text-gray-400 hover:text-white transition">Términos de servicio</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-12 border-t border-gray-800 pt-8 flex flex-col items-center">
      <p class="text-base text-gray-500 xl:text-center">&copy; {currentYear} Noticias Globales. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

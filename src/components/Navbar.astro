---
const currentPath = new URL(Astro.request.url).pathname;
const url = new URL(Astro.request.url);
const isEducational = url.searchParams.has('educational');

const links = [
  { name: 'Portada', href: '/' },
  { name: 'Internacional', href: '/seccion/internacional' },
  { name: 'Política', href: '/seccion/política' },
  { name: 'Economía', href: '/seccion/economía' },
  { name: 'Sociedad', href: '/seccion/sociedad' },
  { name: 'Tecnología', href: '/seccion/tecnología' },
  { name: 'Cultura', href: '/seccion/cultura' },
  { name: 'Deporte', href: '/seccion/deporte' },
  { name: 'MODO TV 📺', href: '/tv', special: true },
];

function buildUrl(path: string) {
    if (isEducational) {
        return `${path}?educational=true`;
    }
    return path;
}
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  {/* Top Accent Bar: Italy + Argentina Colors */}
  <div class="h-1.5 w-full flex">
    <div class="flex-1 bg-[#008C45]"></div> {/* Ita Green */}
    <div class="flex-1 bg-white"></div>     {/* Ita White */}
    <div class="flex-1 bg-[#CD212A]"></div> {/* Ita Red */}
    <div class="flex-1 bg-[#74ACDF]"></div> {/* Arg Blue */}
    <div class="flex-1 bg-white"></div>     {/* Arg White */}
    <div class="flex-1 bg-[#74ACDF]"></div> {/* Arg Blue */}
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      {/* Logo */}
      <div class="flex-shrink-0 flex items-center">
        <a href={buildUrl('/')} class="text-3xl font-serif font-black tracking-tight text-gray-900 hover:text-gray-700 transition-colors">
          Noticias<span class="text-[#008C45]">.</span><span class="text-[#CD212A]">Global</span>
        </a>
      </div>

      {/* Desktop Navigation */}
      <nav class="hidden md:flex space-x-8">
        {links.map(link => {
            // For root, exact match. For others, startsWith
            const isActive = link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href) || currentPath.includes(encodeURI(link.href));
            return (
              <a 
                href={buildUrl(link.href)} 
                class={`inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors ${
                  link.special 
                    ? 'text-[#CD212A] border-[#CD212A] font-black' 
                    : isActive 
                        ? 'border-[#008C45] text-gray-900' 
                        : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'
                }`}
              >
                {link.name}
                {link.special && (
                    <span class="flex h-2 w-2 ml-2">
                      <span class="animate-ping absolute inline-flex h-2 w-2 rounded-full bg-red-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-red-600"></span>
                    </span>
                )}
              </a>
            );
        })}
      </nav>

      {/* Utilities */}
      <div class="hidden md:flex items-center space-x-4">
        {/* Educational Mode Toggle */}
        <form action="" method="get" class="flex items-center">
            {/* Persist existing category in the form action automatically by submitting to same URL */}
            <input type="checkbox" id="edu-toggle" name="educational" value="true" checked={isEducational} class="sr-only peer" onchange="this.form.submit()" />
            <label for="edu-toggle" class="relative inline-flex items-center cursor-pointer">
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#008C45]"></div>
              <span class="ml-3 text-sm font-medium text-gray-700 select-none">Modo Aula</span>
            </label>
        </form>
      </div>

      {/* Mobile menu button */}
      <div class="flex items-center md:hidden">
        <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#CD212A]" aria-controls="mobile-menu" aria-expanded="false" id="mobile-menu-btn">
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  {/* Mobile menu */}
  <div class="md:hidden hidden bg-white border-t border-gray-200" id="mobile-menu">
    <div class="pt-2 pb-3 space-y-1">
      {links.map(link => {
          const isActive = link.href === '/' ? currentPath === '/' : currentPath.includes(encodeURI(link.href));
          return (
            <a 
              href={buildUrl(link.href)} 
              class={`block pl-3 pr-4 py-2 border-l-4 text-base font-medium ${
                isActive 
                  ? 'bg-red-50 border-[#CD212A] text-[#CD212A]' 
                  : 'border-transparent text-gray-500 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-700'
              }`}
            >
              {link.name}
            </a>
          );
      })}
    </div>
    <div class="pt-4 pb-4 border-t border-gray-200 px-4">
        <form action="" method="get" class="flex items-center justify-between">
            <span class="text-base font-medium text-gray-900">Modo Aula (Educativo)</span>
            <input type="checkbox" id="edu-toggle-mobile" name="educational" value="true" checked={isEducational} class="sr-only peer" onchange="this.form.submit()" />
            <label for="edu-toggle-mobile" class="relative inline-flex items-center cursor-pointer">
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#008C45]"></div>
            </label>
        </form>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    if (btn && menu) {
        btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        });
    }
  });
</script>
